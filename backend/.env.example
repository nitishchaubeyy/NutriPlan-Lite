# Server Configuration
PORT=4000
NODE_ENV=development

# CORS Configuration
# Set to the exact origin of your frontend (e.g. https://nutriplan-lite.vercel.app).
# Only this origin will be allowed to make cross-origin requests to the API.
# For local development the default fallback is http://localhost:3000.
ALLOWED_ORIGIN=http://localhost:3000

# Database Configuration
DATABASE_URL=postgresql://db_user:db_password@db_host:db_port/db_name
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=nutriplan_lite

# Logging Configuration
LOG_LEVEL=info

# JWT Authentication Configuration
# REQUIRED: JWT secret for authentication
# Use a strong random string (minimum 32 characters)
JWT_SECRET=your_super_secure_random_secret_here
JWT_EXPIRES_IN=7d
